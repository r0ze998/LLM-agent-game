# Server
PORT=3001
CORS_ORIGIN=http://localhost:5176

# LLM Provider — "anthropic" (default) | "openai" | "ollama"
LLM_PROVIDER=anthropic

# Anthropic (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (required when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o-mini

# Ollama (local, free — default model: qwen2.5:3b)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5:3b

# Headless mode — auto-start a game without browser
# HEADLESS=true
# HEADLESS_SPEED=4
# HEADLESS_SEED=42
# HEADLESS_AUTOSAVE_INTERVAL=500

# Dojo on-chain bridge (optional — Starknet/Katana)
# DOJO_ENABLED=false
# DOJO_RPC_URL=http://localhost:5050

# x402 Payment Layer (optional)
X402_ENABLED=false
X402_PAY_TO_ADDRESS=0x...
X402_NETWORK=eip155:84532
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_AGENT_MNEMONIC=
X402_PRICE_INTENTION=$0.001
X402_PRICE_CHRONICLE=$0.005
X402_PRICE_BIOGRAPHY=$0.003
X402_PRICE_BLUEPRINT=$0.01
# On-chain settlement (optional — set to true for real USDC transfers)
X402_ONCHAIN_ENABLED=false
X402_RPC_URL=https://sepolia.base.org
