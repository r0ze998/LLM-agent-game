# Server
PORT=3001
CORS_ORIGIN=http://localhost:5176

# LLM Provider — "anthropic" (default) | "openai" | "ollama"
LLM_PROVIDER=anthropic

# Anthropic (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (required when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o-mini

# Ollama (local, free — default model: qwen2.5:3b)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5:3b

# Headless mode — auto-start a game without browser
# HEADLESS=true
# HEADLESS_SPEED=4
# HEADLESS_SEED=42
# HEADLESS_AUTOSAVE_INTERVAL=500

# Dojo on-chain bridge (optional — Starknet/Katana)
# DOJO_ENABLED=false
# DOJO_RPC_URL=http://localhost:5050

# Sepolia testnet (uncomment to use Sepolia instead of Katana)
# DOJO_ENABLED=true
# DOJO_RPC_URL=https://starknet-sepolia.public.blastapi.io
# DOJO_ACCOUNT_ADDRESS=0x<your_funded_sepolia_account>
# DOJO_PRIVATE_KEY=0x<your_sepolia_private_key>
# DOJO_MANIFEST_PATH=../../contracts/manifest_sepolia.json
